generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum RefundStatus {
  CREATED
  PROCESSED
  FAILED
}

enum SubscriptionStatus {
  CREATED
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  EXPIRED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  REVENUE
  EXPENSE
}

//////////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////////

model Payment {
  id                BigInt   @id @default(autoincrement())

  externalRef       String
  sourceApp         String
  provider          String   @default("razorpay")

  razorpayOrderId   String?  @unique
  razorpayPaymentId String?  @unique

  amountPaise       BigInt   @db.BigInt
  currency          String   @db.VarChar(3)

  status            PaymentStatus @default(CREATED)

  method            String?
  email             String?
  contact           String?

  metadata          Json?

  capturedAt        DateTime?

  refunds           Refund[]
  ledgerEntries     LedgerEntry[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([externalRef])
  @@index([sourceApp])
}

//////////////////////////////////////////////////////////
// REFUNDS
//////////////////////////////////////////////////////////

model Refund {
  id               BigInt   @id @default(autoincrement())

  paymentId        BigInt
  payment          Payment  @relation(fields: [paymentId], references: [id])

  razorpayRefundId String?  @unique

  amountPaise      BigInt   @db.BigInt
  status           RefundStatus @default(CREATED)

  reason           String?

  ledgerEntries    LedgerEntry[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([paymentId])
}

//////////////////////////////////////////////////////////
// IDEMPOTENCY
//////////////////////////////////////////////////////////

model IdempotencyKey {
  id          BigInt   @id @default(autoincrement())

  scope       String
  idemKey     String
  requestHash String
  response    Json

  createdAt   DateTime @default(now())

  @@unique([scope, idemKey])
  @@index([createdAt])
}

//////////////////////////////////////////////////////////
// WEBHOOK EVENTS
//////////////////////////////////////////////////////////

model WebhookEvent {
  id         BigInt   @id @default(autoincrement())

  eventId    String   @unique
  eventType  String

  body       Json

  paymentId  String?

  processed  Boolean  @default(false)

  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([eventType])
  @@index([processed])
}

//////////////////////////////////////////////////////////
// SUBSCRIPTIONS
//////////////////////////////////////////////////////////

model Subscription {
  id                     BigInt    @id @default(autoincrement())

  externalRef            String
  sourceApp              String?

  customerRef            String

  razorpaySubscriptionId String?   @unique
  razorpayPlanId         String?
  razorpayCustomerId     String?

  status                 SubscriptionStatus @default(CREATED)

  quantity               Int?
  totalCount             Int?
  paidCount              Int?
  remainingCount         Int?

  amountPaise            BigInt?   @db.BigInt
  currency               String?   @db.VarChar(3)

  currentStart           DateTime?
  currentEnd             DateTime?

  metadata               Json?

  invoices               Invoice[]

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([externalRef])
  @@index([customerRef])
}

//////////////////////////////////////////////////////////
// INVOICES
//////////////////////////////////////////////////////////

model Invoice {
  id                BigInt        @id @default(autoincrement())

  subscriptionId    BigInt?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])

  razorpayInvoiceId String?       @unique
  razorpayPaymentId String?

  amountPaise       BigInt?       @db.BigInt
  currency          String?       @db.VarChar(3)

  status            InvoiceStatus?

  dueAt             DateTime?
  paidAt            DateTime?

  metadata          Json?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([subscriptionId])
}

//////////////////////////////////////////////////////////
// LEDGER ACCOUNTS
//////////////////////////////////////////////////////////

model LedgerAccount {
  id          BigInt  @id @default(autoincrement())

  name        String
  type        LedgerAccountType

  externalRef String?

  metadata    Json?

  entries     LedgerEntry[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([externalRef])
}

//////////////////////////////////////////////////////////
// LEDGER ENTRIES (IMMUTABLE)
//////////////////////////////////////////////////////////

model LedgerEntry {
  id          BigInt   @id @default(autoincrement())

  accountId   BigInt
  account     LedgerAccount @relation(fields: [accountId], references: [id])

  paymentId   BigInt?
  payment     Payment? @relation(fields: [paymentId], references: [id])

  refundId    BigInt?
  refund      Refund? @relation(fields: [refundId], references: [id])

  entryType   LedgerEntryType

  amountPaise BigInt   @db.BigInt
  currency    String   @db.VarChar(3)

  description String?

  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([accountId])
  @@index([paymentId])
  @@index([refundId])
}